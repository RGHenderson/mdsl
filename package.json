{
  "name": "@rghenderson/mdsl",
  "version": "0.1.0",
  "description": "Markdown Structured Language — define typed schemas for markdown documents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RGHenderson/mdsl.git"
  },
  "homepage": "https://github.com/RGHenderson/mdsl#readme",
  "bugs": {
    "url": "https://github.com/RGHenderson/mdsl/issues"
  },
  "keywords": ["markdown", "schema", "zod", "parser", "serializer", "llm", "structured"],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --config .oxlintrc.json --tsconfig tsconfig.json src/ tests/",
    "format": "oxfmt src/ tests/",
    "format:check": "oxfmt --check src/ tests/",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm test && npm run build",
    "prepare": "husky",
    "release": "commit-and-tag-version",
    "release:first": "commit-and-tag-version --first-release",
    "release:dry": "commit-and-tag-version --dry-run"
  },
  "dependencies": {
    "mdast-util-gfm": "^3.0.0",
    "mdast-util-to-markdown": "^2.0.0",
    "mdast-util-to-string": "^4.0.0",
    "remark": "^15.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "yaml": "^2.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/node": "^22.0.0",
    "commit-and-tag-version": "^12.7.3",
    "husky": "^9.1.7",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.16.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "optionalDependencies": {
    "@oxfmt/binding-darwin-arm64": "^0.56.0",
    "@oxfmt/binding-darwin-x64": "^0.56.0",
    "@oxfmt/binding-linux-x64-gnu": "^0.56.0",
    "@oxfmt/binding-linux-arm64-gnu": "^0.56.0",
    "@oxfmt/binding-win32-x64-msvc": "^0.56.0"
  },
  "engines": {
    "node": ">=18"
  }
}
